rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasAllowedRoleOnCreate() {
      return request.resource.data.role == 'apprenant';
    }

    function keepsSameRoleOnUpdate() {
      return !('role' in request.resource.data)
        || !('role' in resource.data)
        || request.resource.data.role == resource.data.role;
    }

    function isConversationParticipant(data) {
      return isSignedIn()
        && data.participants is list
        && request.auth.uid in data.participants;
    }

    function isStudentRecord(data) {
      return isSignedIn()
        && data.studentId is string
        && data.studentId == request.auth.uid;
    }

    function isCoachRecord(data) {
      return isSignedIn()
        && data.coachId is string
        && data.coachId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && hasAllowedRoleOnCreate();
      allow update: if isOwner(userId) && keepsSameRoleOnUpdate();
      allow delete: if false;
    }

    match /conversations/{conversationId} {
      allow read: if isConversationParticipant(resource.data);
      allow create: if isSignedIn()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants;
      allow update: if isConversationParticipant(resource.data)
        && request.resource.data.participants == resource.data.participants;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isConversationParticipant(
          get(/databases/$(database)/documents/conversations/$(conversationId)).data
        );
        allow create: if isSignedIn()
          && request.resource.data.senderId == request.auth.uid
          && isConversationParticipant(
            get(/databases/$(database)/documents/conversations/$(conversationId)).data
          );
        allow update, delete: if false;
      }
    }

    match /courses/{document=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /masterclasses/{document=**} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /masterclassRegistrations/{registrationId} {
      allow read: if isStudentRecord(resource.data) || isCoachRecord(resource.data);
      allow create: if isStudentRecord(request.resource.data);
      allow delete: if isStudentRecord(resource.data);
      allow update: if isCoachRecord(resource.data);
    }

    match /courseRequests/{requestId} {
      allow read: if isStudentRecord(resource.data) || isCoachRecord(resource.data);
      allow create: if isStudentRecord(request.resource.data);
      allow delete: if isStudentRecord(resource.data);
      allow update: if isCoachRecord(resource.data);
    }
  }
}
